{
  "version": 1,
  "site": "cs",
  "sections": [
    {
      "id": "header",
      "label": "Header",
      "fields": [
        { "path": "documentTitle", "type": "text", "label": "Título de la página (SEO)", "maxLength": 120 },
        { "path": "header.regionBadge", "type": "text", "label": "Badge de región", "maxLength": 30 },
        { "path": "header.partnerLink.prefix", "type": "text", "label": "Prefijo partner", "maxLength": 40 },
        { "path": "header.partnerLink.name",   "type": "text", "label": "Nombre partner", "maxLength": 60 },
        { "path": "header.partnerLink.href",   "type": "href", "label": "Link partner" },
        { "path": "header.ctaWhatsapp.label",  "type": "text", "label": "CTA WhatsApp — texto", "maxLength": 30 },
        { "path": "header.ctaWhatsapp.href",   "type": "href", "label": "CTA WhatsApp — link" },
        { "path": "header.ctaPrimary.label",   "type": "text", "label": "CTA primario — texto", "maxLength": 30 },
        { "path": "header.ctaPrimary.href",    "type": "href", "label": "CTA primario — link" },
        {
          "path": "header.nav",
          "type": "array",
          "label": "Nav links",
          "summary": "label",
          "itemLabel": "Link",
          "minItems": 1,
          "maxItems": 12,
          "itemSchema": [
            { "path": "id",    "type": "text", "label": "ID" },
            { "path": "label", "type": "text", "label": "Label", "maxLength": 30 },
            { "path": "href",  "type": "href", "label": "Href" }
          ]
        }
      ]
    },
    {
      "id": "hero",
      "label": "Hero (slider principal)",
      "fields": [
        { "path": "hero.scrollHint", "type": "text", "label": "Scroll hint", "maxLength": 20 },
        {
          "path": "hero.slides",
          "type": "array",
          "label": "Slides del Hero",
          "summary": "eyebrow",
          "itemLabel": "Slide",
          "minItems": 1,
          "maxItems": 8,
          "itemSchema": [
            { "path": "id",         "type": "text",      "label": "ID slug" },
            { "path": "kind",       "type": "text",      "label": "Tipo (video|image)" },
            { "path": "videoUrl",   "type": "text",      "label": "Video URL (si kind=video)" },
            { "path": "videoTitle", "type": "text",      "label": "Video title" },
            { "path": "posterImg",  "type": "imageSrc",  "label": "Imagen mobile / fallback" },
            { "path": "posterAlt",  "type": "text",      "label": "Alt imagen" },
            { "path": "eyebrow",    "type": "text",      "label": "Eyebrow", "maxLength": 60 },
            { "path": "titleHtml",  "type": "text-html", "label": "Título (br/strong)" },
            { "path": "ctaLabel",   "type": "text",      "label": "CTA texto", "maxLength": 30 },
            { "path": "ctaHref",    "type": "href",      "label": "CTA link" }
          ]
        }
      ]
    },
    {
      "id": "trust",
      "label": "Trust strip",
